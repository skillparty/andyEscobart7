# URL del deployment de Convex (la genera `bunx convex dev` en .env.local)
VITE_CONVEX_URL=

# Estas variables NO van aquí: se configuran en el deployment de Convex:
#   bunx convex env set AUTH_GOOGLE_ID <client-id-de-google>
#   bunx convex env set AUTH_GOOGLE_SECRET <client-secret-de-google>
#   bunx convex env set SITE_URL http://localhost:3000
